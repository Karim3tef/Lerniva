# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lerniva

# JWT
JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Bunny Stream
BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_API_KEY=your-bunny-api-key
BUNNY_CDN_HOSTNAME=your-cdn-hostname.b-cdn.net
BUNNY_WEBHOOK_SECRET=your-bunny-webhook-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Email
EMAIL_PROVIDER=smtp
# EMAIL_PROVIDER=resend

# Resend Email Provider (recommended – fast API-based delivery)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=Lerniva <no-reply@your-verified-domain.com>

# SMTP Provider (alternative)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxx

EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_HOURS=24
